{
	"name": "meh-more-excellent-hotkeys",
	"version": "2.1.0",
	"description": "MEH: More Excellent Hotkeys",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"build:dev": "node esbuild.config.mjs",
		"watcher": "DEST='/media/win/#blackhole/.obsidian/plugins/meh-more-excellent-hotkeys/' && mkdir -p \"$DEST\" && ls main.js manifest.json styles.css | entr cp main.js manifest.json styles.css \"$DEST\"",
		"dev": "concurrently --kill-others --names \"build,watch\" -c \"cyan,magenta\" \"pnpm build:dev\" \"pnpm watcher\"",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "tsc -noEmit -skipLibCheck && oxlint",
		"test": "node --import tsx --test test/*.test.ts"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/state": "^6.4.1",
		"@types/node": "^22.9.0",
		"builtin-modules": "4.0.0",
		"codemirror": "^6.0.1",
		"concurrently": "^9.2.1",
		"esbuild": "0.24.0",
		"happy-dom": "^15.11.6",
		"obsidian": "latest",
		"oxlint": "^1.60.0",
		"tslib": "2.8.1",
		"tsx": "^4.19.2",
		"typescript": "5.6.3"
	}
}
